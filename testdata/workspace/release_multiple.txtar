# Test releasing multiple workspaces at once

# setup repo
mkdir repo
cd repo
exec jj git init

# acquire two workspaces
exec $II workspace acquire --purpose first-workspace
envset WORKSPACE_PATH_1 stdout

exec $II workspace acquire --purpose second-workspace
envset WORKSPACE_PATH_2 stdout

# verify both workspaces are acquired
exec $II workspace list
stdout 'ws-001.*acquired'
stdout 'ws-002.*acquired'

# release both at once
exec $II workspace release ws-001 ws-002
stdout 'released workspace ws-001'
stdout 'released workspace ws-002'

# verify both workspaces are now available
exec $II workspace list
stdout 'ws-001.*available'
stdout 'ws-002.*available'
