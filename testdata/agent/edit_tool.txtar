# Test that the agent can use the edit tool to modify files.
# This verifies that tool call arguments are properly parsed.

# Setup: create repo and copy the real config
mkdir repo
cd repo
exec jj git init
cp ../incrementum.toml incrementum.toml

# Create a file for the agent to edit
cp ../original.txt document.txt

# Run agent asking it to edit the file
exec $II agent run --model claude-haiku-4-5 'Use the edit tool to modify "document.txt": replace the word "World" with "Universe". Do not use bash.'

# Verify the edit was made
exec cat document.txt
stdout 'Hello, Universe!'
! stdout 'World'

-- original.txt --
Hello, World!
