# Test that the default agent model can use the bash tool with a simple touch command.
# This is a minimal test case to verify basic tool functionality.

# Setup: create repo and copy the real config
mkdir repo
cd repo
exec jj git init
cp ../incrementum.toml incrementum.toml

# Run agent asking it to touch a file.
# Intentionally do not pass --model so we exercise the default model selection path
# used by `ii agent run 'touch hello-world.txt'`.
exec $II agent run 'touch hello-world.txt'

# Verify the file was created
exists hello-world.txt
