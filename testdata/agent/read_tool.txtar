# Test that the agent can use the read tool to read files.
# This verifies that tool call arguments are properly parsed.

# Setup: create repo and copy the real config
mkdir repo
cd repo
exec jj git init
cp ../incrementum.toml incrementum.toml

# Create a file for the agent to read
cp ../secret.txt secret.txt

# Run agent asking it to read the file - be explicit about the relative path
exec $II agent run --model claude-haiku-4-5 'Use the read tool to read the file at path "./secret.txt" (relative path in current directory) and tell me what the secret code is.'

# The agent should report the secret code in its response
stdout 'XYZZY'

-- secret.txt --
The secret code is: XYZZY
