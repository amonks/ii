# Test that the agent recovers from permission denied errors.
# This verifies that tool errors are fed back to the model for retry.

# Setup: create repo and copy the real config
mkdir repo
cd repo
exec jj git init
cp ../incrementum.toml incrementum.toml

# Create a read-only directory to trigger permission error
mkdir protected
chmod 000 protected

# Ask the agent to create a file - it should try protected first, get error, then succeed in repo
exec $II agent run --model claude-haiku-4-5 'Create a file called test.txt in the current directory with content "success"'

# Verify the file was created
exists test.txt
exec cat test.txt
stdout 'success'

# Cleanup
chmod 755 protected
