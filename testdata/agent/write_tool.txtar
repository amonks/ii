# Test that the agent can use the write tool to create files.
# This verifies that tool call arguments are properly parsed.

# Setup: create repo and copy the real config
mkdir repo
cd repo
exec jj git init
cp ../incrementum.toml incrementum.toml

# Run agent asking it to use the write tool - be explicit about using relative path
exec $II agent run --model claude-haiku-4-5 'Use the write tool (not bash) to create a file. The path should be "./greeting.txt" (relative to current directory). The content should be exactly "Hello, World!" with no trailing newline.'

# Verify the file was created
exists greeting.txt
exec cat greeting.txt
stdout 'Hello, World!'
