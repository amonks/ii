<!doctype html>
<html>
<head>
<title>air</title>
</head>

<body>

<div id="graphs"></div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/moment@^2"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-moment@^1"></script>

<script>
{{ .JSON }}

container = document.getElementById("graphs")
function graph(id, data) {
  const h1 = document.createElement("h1");
  h1.innerText = id;
  container.appendChild(h1);

  const canvas = document.createElement("canvas");
  canvas.id = id;
  container.appendChild(canvas);

  new Chart(document.getElementById(id), {
      type: 'line',
      data: {
          datasets: [
              {
                  label: "max",
                  data: data.map(d => ({x: d.WindowStartAt, y: d.Max})),
                  fill: 2,
                  below: "rgb(255,0,0)",
              }, {
                  label: "mean",
                  data: data.map(d => ({x: d.WindowStartAt, y: d.Mean})),
              }, {
                  label: "min",
                  data: data.map(d => ({x: d.WindowStartAt, y: d.Min})),
              }
          ],
      },
      options: {
          animation: false,
          borderWidth: 1,
          pointRadius: 1,
          showLine: true,
          plugins: {
              legend: false
          },
          scales: {
              x: {
                  unit: "minute",
                  type: "time",
              }
          }
      }
  });
}

// Venta data
graph("venta-dust", data.Dust);
graph("venta-temperature", data.Temperature);
graph("venta-humidity", data.Humidity);
graph("venta-waterLevel", data.WaterLevel);

// Office Aranet data
if (data.OfficeTemperature && data.OfficeTemperature.length > 0) {
  graph("office-temperature", data.OfficeTemperature);
  graph("office-humidity", data.OfficeHumidity);
  graph("office-co2", data.OfficeCO2);
  graph("office-pressure", data.OfficePressure);
}

// Living Room Aranet data
if (data.LivingRoomTemperature && data.LivingRoomTemperature.length > 0) {
  graph("livingroom-temperature", data.LivingRoomTemperature);
  graph("livingroom-humidity", data.LivingRoomHumidity);
  graph("livingroom-co2", data.LivingRoomCO2);
  graph("livingroom-pressure", data.LivingRoomPressure);
}
</script>
</body>
</html>

