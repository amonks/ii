<!doctype html>
<html>
<head>
<title>air</title>
</head>

<body>

<div id="graphs"></div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/moment@^2"></script>
<script src="https://cdn.jsdelivr.net/npm/chartjs-adapter-moment@^1"></script>

<script>
{{ .JSON }}

container = document.getElementById("graphs")
function graph(id, data) {
  const h1 = document.createElement("h1");
  h1.innerText = id;
  container.appendChild(h1);

  const canvas = document.createElement("canvas");
  canvas.id = id;
  container.appendChild(canvas);

  new Chart(document.getElementById(id), {
      type: 'line',
      data: {
          datasets: [
              {
                  label: "max",
                  data: data.map(d => ({x: d.WindowStartAt, y: d.Max})),
                  fill: 2,
                  below: "rgb(255,0,0)",
              }, {
                  label: "mean",
                  data: data.map(d => ({x: d.WindowStartAt, y: d.Mean})),
              }, {
                  label: "min",
                  data: data.map(d => ({x: d.WindowStartAt, y: d.Min})),
              }
          ],
      },
      options: {
          animation: false,
          borderWidth: 1,
          pointRadius: 1,
          showLine: true,
          plugins: {
              legend: false
          },
          scales: {
              x: {
                  unit: "minute",
                  type: "time",
              }
          }
      }
  });
}

graph("dust", data.Dust);
graph("temperature", data.Temperature);
graph("humidity", data.Humidity);
graph("waterLevel", data.WaterLevel);
</script>
</body>
</html>

