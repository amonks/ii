package templates

import (
	"monks.co/apps/posts/model"
)

templ Index(posts *model.Posts) {
	@page("posts") {
		<ul>
			for _, post := range posts.List {
				if !post.IsDraft {
					<li>
						<a href={templ.SafeURL(post.Slug)}></a>
						<em>
							{ post.Date }
						</em>
						{ post.Title }
					</li>
				}
			}
		</ul>
	}
}
