package server

import "fmt"

templ XPSection(view *CharacterView) {
	@CardDisclosure("xp", true) {
		@CardDisclosureHeader() {
			@XPSummary(view)
		}
		@CardDisclosureBody() {
		@CardSection() {
			@SectionHeader() { Progress }
			@ProgressBar(xpBarWidth(view))
			@ProgressLabel() {
				{ fmt.Sprintf("%d", view.XPToNext) } XP to level { fmt.Sprintf("%d", view.Character.Level+1) }
			}
			if view.CanLevelUp {
				@BtnWide("pulse", templ.Attributes{
					"hx-post": "level-up/",
					"hx-target": "#sheet-body",
					"hx-swap": "innerHTML",
					"hx-confirm": fmt.Sprintf("Level up to level %d?", view.NewLevel),
				}) {
					Level Up to { fmt.Sprintf("%d", view.NewLevel) }!
				}
			}
		}
		@CardSection() {
			@SectionHeader() { Add XP }
			<form hx-post="xp/" hx-target="#sheet-body" hx-swap="innerHTML">
				@FormRowAligned() {
					@FormInputNumberNarrow(templ.Attributes{"name": "xp_amount", "placeholder": "XP", "required": true})
					@FormInput(templ.Attributes{"name": "description", "placeholder": "Description"})
					@BtnPrimary() { Add XP }
				}
			</form>
		}
		if len(view.XPLog) > 0 {
			@CardSection() {
				@SectionHeader() { XP Log }
				@Details() {
					@Summary() { Show }
					@DetailsBody() {
						for _, entry := range view.XPLog {
							@LogEntry() {
								<span>{ entry.Description }</span>
								@Accent("medium") { +{ fmt.Sprintf("%d", entry.Amount) } }
							}
						}
					}
				}
			}
		}
		if entries := filterAuditLog(view.AuditLog, "xp_add", "return_to_safety"); len(entries) > 0 {
			@CardSection() {
				@SectionHeader() { XP Audit Log }
				@Details() {
					@Summary() { Show }
					@DetailsBody() {
						for _, entry := range entries {
							@LogEntry() {
								<span>{ entry.Detail }</span>
								@auditDate(entry)
							}
						}
					}
				}
			}
		}
		}
	}
}


templ XPSummary(view *CharacterView) {
	@Header() {
		@Heading() { Experience }
		@Label() {
			{ fmt.Sprintf("%d", view.Character.TotalXP) } XP (mod { formatMod(view.XPModPercent) }%)
		}
	}
}
