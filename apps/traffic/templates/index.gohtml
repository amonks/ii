<!doctype html>
<html>

<head>
<title>traffic</title>
<link rel="stylesheet" type="text/css" href="index.css" />
<style>
  .chart-container {
    margin: 2rem 1rem;
    background-color: rgb(30 41 59);
    border-radius: 8px;
    padding: 20px;
  }
  .chart-container h2 {
    color: #e2e8f0;
    margin: 0 0 12px 0;
    font-size: 14px;
    font-weight: 600;
  }
  .d3-chart {
    width: 100%;
    height: 350px;
  }
  .axis path, .axis line { fill: none; stroke: #475569; shape-rendering: crispEdges; }
  .axis text { font-size: 11px; fill: #94a3b8; }
  .grid line { stroke: #334155; shape-rendering: crispEdges; }
  .grid path { stroke-width: 0; }
  .chart-line { fill: none; stroke-width: 2; }
  .legend { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 8px; }
  .legend-item { display: flex; align-items: center; font-size: 12px; color: #94a3b8; }
  .legend-color { width: 12px; height: 3px; margin-right: 5px; border-radius: 1px; }
  .chart-tooltip {
    position: absolute;
    pointer-events: none;
    background: rgba(15, 23, 42, 0.95);
    border: 1px solid #475569;
    border-radius: 4px;
    padding: 8px;
    font-size: 12px;
    color: #e2e8f0;
  }
  .chart-tooltip .tt-title { font-weight: bold; margin-bottom: 4px; border-bottom: 1px solid #334155; padding-bottom: 4px; }
  .chart-tooltip .tt-row { margin-top: 2px; }
  .range-picker {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 1.5rem 1rem 0;
    flex-wrap: wrap;
  }
  .range-picker a {
    padding: 5px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
    color: #94a3b8;
    text-decoration: none;
    background: rgb(30 41 59);
    border: 1px solid transparent;
  }
  .range-picker a:hover { color: #e2e8f0; }
  .range-picker a.active {
    color: #e2e8f0;
    border-color: #475569;
    background: rgb(51 65 85);
  }
  .range-picker .sep { color: #475569; font-size: 12px; margin: 0 2px; }
  .range-picker input[type="date"] {
    background: rgb(30 41 59);
    border: 1px solid #475569;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 12px;
    padding: 4px 8px;
    color-scheme: dark;
  }
  .range-picker button {
    background: rgb(51 65 85);
    border: 1px solid #475569;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 12px;
    padding: 5px 12px;
    cursor: pointer;
  }
  .range-picker button:hover { background: rgb(71 85 105); }
  .panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 0 1rem;
  }
  @media (max-width: 768px) {
    .panels { grid-template-columns: 1fr; }
  }
  .panel {
    background-color: rgb(30 41 59);
    border-radius: 8px;
    padding: 16px;
  }
  .panel h2 {
    color: #e2e8f0;
    margin: 0 0 12px 0;
    font-size: 14px;
    font-weight: 600;
  }
  .panel table { width: 100%; }
  .panel td { padding: 4px 0; font-size: 13px; }
  .panel td:last-child { text-align: right; }
  .status-2xx { color: #34d399; }
  .status-3xx { color: #60a5fa; }
  .status-4xx { color: #fbbf24; }
  .status-5xx { color: #f87171; }
  .dur-row { display: flex; align-items: center; gap: 8px; margin: 4px 0; font-size: 13px; }
  .dur-label { width: 60px; text-align: right; color: #94a3b8; flex-shrink: 0; }
  .dur-bar-bg { flex: 1; height: 18px; background: rgb(51 65 85); border-radius: 3px; overflow: hidden; }
  .dur-bar { height: 100%; background: #60a5fa; border-radius: 3px; min-width: 1px; }
  .dur-count { width: 70px; text-align: right; color: #94a3b8; flex-shrink: 0; }

  /* Query builder styles */
  .query-builder {
    margin: 1rem 1rem 0;
    background-color: rgb(30 41 59);
    border-radius: 8px;
    padding: 16px;
  }
  .query-builder h2 {
    color: #e2e8f0;
    margin: 0 0 12px 0;
    font-size: 14px;
    font-weight: 600;
  }
  .query-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .query-swatch {
    width: 14px;
    height: 14px;
    border-radius: 3px;
    flex-shrink: 0;
  }
  .query-row select {
    background: rgb(51 65 85);
    border: 1px solid #475569;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 12px;
    padding: 4px 8px;
  }
  .query-filters {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }
  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: rgb(51 65 85);
    border: 1px solid #475569;
    border-radius: 12px;
    padding: 2px 8px;
    font-size: 11px;
    color: #e2e8f0;
  }
  .filter-pill .remove-filter {
    cursor: pointer;
    color: #94a3b8;
    font-size: 13px;
    line-height: 1;
  }
  .filter-pill .remove-filter:hover { color: #f87171; }
  .query-btn {
    background: none;
    border: 1px solid #475569;
    border-radius: 4px;
    color: #94a3b8;
    font-size: 11px;
    padding: 3px 8px;
    cursor: pointer;
  }
  .query-btn:hover { color: #e2e8f0; border-color: #64748b; }
  .query-btn.remove { color: #f87171; border-color: transparent; }
  .query-btn.remove:hover { color: #ef4444; }
  .add-query-btn {
    background: none;
    border: 1px dashed #475569;
    border-radius: 4px;
    color: #94a3b8;
    font-size: 12px;
    padding: 5px 12px;
    cursor: pointer;
    margin-top: 4px;
  }
  .add-query-btn:hover { color: #e2e8f0; border-color: #64748b; }
  .filter-add {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .filter-add select {
    background: rgb(51 65 85);
    border: 1px solid #475569;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 11px;
    padding: 2px 6px;
  }
</style>
</head>

<body class="bg-slate-900 text-gray-100">
  <div class="px-4 sm:px-6 lg:px-8">

    <div class="range-picker">
      {{ range .TimeRange.CannedRanges }}
        <a href="?range={{ .Key }}"{{ if .Active }} class="active"{{ end }}>{{ .Label }}</a>
      {{ end }}
      <span class="sep">|</span>
      <form method="get" style="display:contents">
        <input type="date" name="start" value="{{ .TimeRange.Start }}">
        <span class="sep">&ndash;</span>
        <input type="date" name="end" value="{{ .TimeRange.End }}">
        <button type="submit">Apply</button>
      </form>
    </div>

    <div class="query-builder">
      <h2>Queries</h2>
      <div id="query-rows"></div>
      <button class="add-query-btn" id="add-query">+ Add query</button>
    </div>

    <div class="chart-container">
      <h2>Requests Over Time</h2>
      <div class="legend" id="chart-legend"></div>
      <div class="d3-chart" id="chart"></div>
    </div>

    <div class="panels">
      <div class="panel">
        <h2>Status Codes</h2>
        <table>
          {{ range .StatusCodes }}
            <tr>
              <td class="{{ if ge .StatusCode 500 }}status-5xx{{ else if ge .StatusCode 400 }}status-4xx{{ else if ge .StatusCode 300 }}status-3xx{{ else }}status-2xx{{ end }}">{{ .StatusCode }}</td>
              <td>{{ .RequestCount }}</td>
            </tr>
          {{ end }}
        </table>
      </div>
      <div class="panel">
        <h2>Duration Distribution</h2>
        {{ range .Durations }}
          <div class="dur-row">
            <span class="dur-label">{{ if ge .DurationBucket 10000 }}>5s{{ else if ge .DurationBucket 1000 }}{{ divide .DurationBucket 1000 }}s{{ else }}{{ .DurationBucket }}ms{{ end }}</span>
            <div class="dur-bar-bg"><div class="dur-bar" style="width: {{ percent .RequestCount $.MaxDurCount }}%"></div></div>
            <span class="dur-count">{{ .RequestCount }}</span>
          </div>
        {{ end }}
      </div>
    </div>

    <div class="mt-8 flow-root">
      <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
	<div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
	  <table class="min-w-full divide-y divide-gray-300">
	    <thead>
	      <tr>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">Top URLs</th>
		<th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-200">Requests</th>
	      </tr>
	    </thead>
	    <tbody class="divide-y divide-gray-500">
	      {{ range .TopPages }}
		<tr>
		  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">{{ .URL }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-right text-sm">{{ .RequestCount }}</td>
		</tr>
	      {{ end }}
	    </tbody>
	  </table>
	</div>
      </div>
      <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
	<div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
	  <table class="min-w-full divide-y divide-gray-300">
	    <thead>
	      <tr>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">Date</th>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">URL</th>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">StatusCode</th>
		<th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-200">Duration</th>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">RemoteAddr</th>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">Referer</th>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">UserAgent</th>
	      </tr>
	    </thead>
	    <tbody class="divide-y divide-gray-500">
	      {{ range .Log }}
		<tr>
		  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">{{ .PrintDate }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm"><a class="text-blue-300" href="//{{ .PrintURL }}">{{ .PrintURL }}</a></td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm">{{ .StatusCode }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm text-right">{{ .PrintDuration }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm" style="color: {{ .ColorRemoteAddr }}">{{ .PrintRemoteAddr }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">{{ .Referer }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">{{ .PrintUserAgent }}</td>
		</tr>
	      {{ end }}
	    </tbody>
	  </table>
	</div>
      </div>
    </div>
  </div>

<script src="https://d3js.org/d3.v7.min.js"></script>
<script>
window.chartData = {{ .ChartJSON }};
window.queries = {{ .QueriesJSON }};

const colors = ["#60a5fa","#f87171","#34d399","#c084fc","#fbbf24","#fb923c","#2dd4bf","#f472b6"];
const formatDate = d3.timeFormat("%b %d, %H:%M");

const groupByOptions = {
  stats: ["host", "status_code", "duration_bucket"],
  pages: ["host", "path"],
};

// Get current range params from URL for API calls.
function getRangeParams() {
  const params = new URLSearchParams(window.location.search);
  const out = new URLSearchParams();
  if (params.has("range")) out.set("range", params.get("range"));
  if (params.has("start")) out.set("start", params.get("start"));
  if (params.has("end")) out.set("end", params.get("end"));
  return out;
}

function formatQuery(q) {
  let parts = ["source:" + q.Source, "group:" + q.GroupBy];
  if (q.Filters) {
    for (const f of q.Filters) {
      const key = (f.Negate ? "!" : "") + f.Column;
      parts.push(key + ":" + f.Values.join("|"));
    }
  }
  return parts.join(",");
}

function updateURL() {
  const params = getRangeParams();
  for (const q of window.queries) {
    params.append("q", formatQuery(q));
  }
  history.replaceState(null, "", "?" + params.toString());
}

async function fetchValues(source, dim) {
  const params = getRangeParams();
  params.set("source", source);
  params.set("dim", dim);
  const resp = await fetch("values?" + params.toString());
  return resp.json();
}

async function fetchQueryData(q) {
  const params = getRangeParams();
  params.set("q", formatQuery(q));
  const resp = await fetch("query?" + params.toString());
  return resp.json();
}

async function refreshChart() {
  const allData = {};
  const results = await Promise.all(window.queries.map(q => fetchQueryData(q)));
  results.forEach((data, i) => {
    for (const [key, pts] of Object.entries(data)) {
      allData["q" + i + ":" + key] = pts;
    }
  });
  window.chartData = allData;
  renderChart(allData);
  updateURL();
}

function renderQueryBuilder() {
  const container = document.getElementById("query-rows");
  container.innerHTML = "";

  window.queries.forEach((q, qi) => {
    const row = document.createElement("div");
    row.className = "query-row";

    // Color swatch
    const swatch = document.createElement("div");
    swatch.className = "query-swatch";
    swatch.style.backgroundColor = colors[qi % colors.length];
    row.appendChild(swatch);

    // Source dropdown
    const srcSel = document.createElement("select");
    srcSel.title = "Data source";
    ["stats", "pages"].forEach(s => {
      const opt = document.createElement("option");
      opt.value = s;
      opt.textContent = s;
      opt.selected = q.Source === s;
      srcSel.appendChild(opt);
    });
    srcSel.addEventListener("change", () => {
      q.Source = srcSel.value;
      // Reset group-by if not valid for new source
      if (!groupByOptions[q.Source].includes(q.GroupBy)) {
        q.GroupBy = groupByOptions[q.Source][0];
      }
      // Remove filters not valid for new source
      if (q.Filters) {
        q.Filters = q.Filters.filter(f => groupByOptions[q.Source].includes(f.Column));
      }
      renderQueryBuilder();
      refreshChart();
    });
    row.appendChild(srcSel);

    // Group-by dropdown
    const grpSel = document.createElement("select");
    grpSel.title = "Group by";
    groupByOptions[q.Source].forEach(g => {
      const opt = document.createElement("option");
      opt.value = g;
      opt.textContent = "group: " + g;
      opt.selected = q.GroupBy === g;
      grpSel.appendChild(opt);
    });
    grpSel.addEventListener("change", () => {
      q.GroupBy = grpSel.value;
      refreshChart();
    });
    row.appendChild(grpSel);

    // Filter pills
    const filtersDiv = document.createElement("div");
    filtersDiv.className = "query-filters";
    if (q.Filters) {
      q.Filters.forEach((f, fi) => {
        const pill = document.createElement("span");
        pill.className = "filter-pill";
        const op = f.Negate
          ? (f.Values.length > 1 ? " not in " : " \u2260 ")
          : (f.Values.length > 1 ? " in " : " = ");
        const valText = f.Values.length > 1 ? f.Values.join(", ") : f.Values[0];

        const labelSpan = document.createElement("span");
        labelSpan.className = "filter-label";
        labelSpan.textContent = f.Column + op + valText;
        labelSpan.title = "Click to toggle negation";
        labelSpan.style.cursor = "pointer";
        labelSpan.addEventListener("click", () => {
          f.Negate = !f.Negate;
          renderQueryBuilder();
          refreshChart();
        });
        pill.appendChild(labelSpan);

        const removeSpan = document.createElement("span");
        removeSpan.className = "remove-filter";
        removeSpan.textContent = "\u00d7";
        removeSpan.addEventListener("click", () => {
          q.Filters.splice(fi, 1);
          renderQueryBuilder();
          refreshChart();
        });
        pill.appendChild(removeSpan);

        filtersDiv.appendChild(pill);
      });
    }

    // +filter button
    const addFilterBtn = document.createElement("button");
    addFilterBtn.className = "query-btn";
    addFilterBtn.textContent = "+filter";
    addFilterBtn.addEventListener("click", () => {
      // Show inline filter add UI
      addFilterBtn.style.display = "none";
      const addDiv = document.createElement("span");
      addDiv.className = "filter-add";

      // Dimension picker: all columns available for this source
      const dimSel = document.createElement("select");
      const availDims = groupByOptions[q.Source];
      if (availDims.length === 0) {
        addFilterBtn.style.display = "";
        return;
      }
      const placeholder = document.createElement("option");
      placeholder.textContent = "dimension...";
      placeholder.value = "";
      dimSel.appendChild(placeholder);
      availDims.forEach(d => {
        const opt = document.createElement("option");
        opt.value = d;
        opt.textContent = d;
        dimSel.appendChild(opt);
      });
      addDiv.appendChild(dimSel);

      // Value picker (populated on dimension change)
      const valSel = document.createElement("select");
      valSel.style.display = "none";
      addDiv.appendChild(valSel);

      const cancelBtn = document.createElement("button");
      cancelBtn.className = "query-btn remove";
      cancelBtn.textContent = "\u00d7";
      cancelBtn.addEventListener("click", () => {
        addDiv.remove();
        addFilterBtn.style.display = "";
      });
      addDiv.appendChild(cancelBtn);

      dimSel.addEventListener("change", async () => {
        if (!dimSel.value) return;
        valSel.innerHTML = "";
        valSel.style.display = "";
        const vp = document.createElement("option");
        vp.textContent = "loading...";
        vp.value = "";
        valSel.appendChild(vp);
        const vals = await fetchValues(q.Source, dimSel.value);
        valSel.innerHTML = "";
        const vph = document.createElement("option");
        vph.textContent = "value...";
        vph.value = "";
        valSel.appendChild(vph);
        (vals || []).forEach(v => {
          const opt = document.createElement("option");
          opt.value = v;
          opt.textContent = v;
          valSel.appendChild(opt);
        });
      });

      valSel.addEventListener("change", () => {
        if (!valSel.value) return;
        if (!q.Filters) q.Filters = [];
        // Check if there's already a filter for this dimension: add to its Values
        const existing = q.Filters.find(f => f.Column === dimSel.value && !f.Negate);
        if (existing) {
          if (!existing.Values.includes(valSel.value)) {
            existing.Values.push(valSel.value);
          }
        } else {
          q.Filters.push({Column: dimSel.value, Negate: false, Values: [valSel.value]});
        }
        renderQueryBuilder();
        refreshChart();
      });

      filtersDiv.appendChild(addDiv);
    });
    filtersDiv.appendChild(addFilterBtn);
    row.appendChild(filtersDiv);

    // Remove query button (only if more than one query)
    if (window.queries.length > 1) {
      const rmBtn = document.createElement("button");
      rmBtn.className = "query-btn remove";
      rmBtn.textContent = "\u00d7";
      rmBtn.title = "Remove query";
      rmBtn.addEventListener("click", () => {
        window.queries.splice(qi, 1);
        renderQueryBuilder();
        refreshChart();
      });
      row.appendChild(rmBtn);
    }

    container.appendChild(row);
  });
}

function renderChart(data) {
  const keys = Object.keys(data || {});
  const chartDiv = document.getElementById("chart");
  const legendEl = document.getElementById("chart-legend");

  // Clear previous
  chartDiv.innerHTML = "";
  legendEl.innerHTML = "";

  // Remove old tooltips
  d3.selectAll(".chart-tooltip").remove();

  if (keys.length === 0) return;

  // Build legend
  keys.forEach((key, i) => {
    const item = document.createElement("div");
    item.className = "legend-item";
    const swatch = document.createElement("div");
    swatch.className = "legend-color";
    swatch.style.backgroundColor = colors[i % colors.length];
    const label = document.createElement("span");
    label.textContent = key;
    item.appendChild(swatch);
    item.appendChild(label);
    legendEl.appendChild(item);
  });

  const margin = {top: 10, right: 20, bottom: 30, left: 50};
  const width = chartDiv.clientWidth - margin.left - margin.right;
  const height = chartDiv.clientHeight - margin.top - margin.bottom;

  const svg = d3.select("#chart").append("svg")
    .attr("width", width + margin.left + margin.right)
    .attr("height", height + margin.top + margin.bottom)
    .append("g")
    .attr("transform", `translate(${margin.left},${margin.top})`);

  const allPoints = [];
  keys.forEach(k => {
    (data[k] || []).forEach(p => {
      p._time = new Date(p.window_start_at);
      allPoints.push(p);
    });
  });

  if (allPoints.length === 0) return;

  const xScale = d3.scaleTime()
    .domain(d3.extent(allPoints, d => d._time))
    .range([0, width]);

  const yScale = d3.scaleLinear()
    .domain([0, d3.max(allPoints, d => d.count) * 1.1])
    .range([height, 0]);

  svg.append("g").attr("class", "grid").attr("transform", `translate(0,${height})`)
    .call(d3.axisBottom(xScale).ticks(10).tickSize(-height).tickFormat(""));
  svg.append("g").attr("class", "grid")
    .call(d3.axisLeft(yScale).ticks(5).tickSize(-width).tickFormat(""));

  svg.append("g").attr("class", "x axis").attr("transform", `translate(0,${height})`)
    .call(d3.axisBottom(xScale).ticks(width > 600 ? 10 : 5).tickFormat(formatDate));
  svg.append("g").attr("class", "y axis")
    .call(d3.axisLeft(yScale).ticks(5));

  const line = d3.line()
    .x(d => xScale(d._time))
    .y(d => yScale(d.count))
    .curve(d3.curveMonotoneX);

  keys.forEach((key, i) => {
    svg.append("path")
      .datum(data[key])
      .attr("class", "chart-line")
      .attr("stroke", colors[i % colors.length])
      .attr("d", line);
  });

  const tooltip = d3.select("body").append("div")
    .attr("class", "chart-tooltip")
    .style("opacity", 0);

  svg.append("rect")
    .attr("width", width).attr("height", height)
    .style("fill", "none").style("pointer-events", "all")
    .on("mouseover", () => tooltip.transition().duration(200).style("opacity", 0.9))
    .on("mouseout", () => tooltip.transition().duration(500).style("opacity", 0))
    .on("mousemove", function(event) {
      const x0 = xScale.invert(d3.pointer(event)[0]);
      let html = `<div class="tt-title">${formatDate(x0)}</div>`;
      const rows = [];
      keys.forEach((key, i) => {
        const pts = data[key];
        if (!pts || pts.length === 0) return;
        const bisect = d3.bisector(d => d._time).left;
        const idx = bisect(pts, x0, 1);
        let d;
        if (idx > 0 && idx < pts.length) {
          const d0 = pts[idx - 1], d1 = pts[idx];
          d = (x0 - d0._time > d1._time - x0) ? d1 : d0;
        } else if (pts.length > 0) {
          d = idx === 0 ? pts[0] : pts[pts.length - 1];
        }
        if (d) rows.push({key, color: colors[i % colors.length], count: d.count});
      });
      rows.sort((a, b) => b.count - a.count);
      rows.forEach(r => {
        html += `<div class="tt-row" style="color:${r.color}">${r.key}: ${r.count}</div>`;
      });
      tooltip.html(html)
        .style("left", (event.pageX + 10) + "px")
        .style("top", (event.pageY - 28) + "px");
    });
}

document.addEventListener("DOMContentLoaded", function() {
  renderQueryBuilder();
  renderChart(window.chartData);

  document.getElementById("add-query").addEventListener("click", () => {
    window.queries.push({Source: "stats", GroupBy: "host", Filters: []});
    renderQueryBuilder();
    refreshChart();
  });
});
</script>
</body>

</html>
