<!doctype html>
<html>

<head>
<title>logs</title>
<link rel="stylesheet" type="text/css" href="index.css" />
<style>
  .chart-container {
    margin: 2rem 1rem;
    background-color: rgb(30 41 59);
    border-radius: 8px;
    padding: 20px;
  }
  .chart-container h2 {
    color: #e2e8f0;
    margin: 0 0 12px 0;
    font-size: 14px;
    font-weight: 600;
  }
  .d3-chart {
    width: 100%;
    height: 350px;
  }
  .axis path, .axis line { fill: none; stroke: #475569; shape-rendering: crispEdges; }
  .axis text { font-size: 11px; fill: #94a3b8; }
  .grid line { stroke: #334155; shape-rendering: crispEdges; }
  .grid path { stroke-width: 0; }
  .legend { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 8px; }
  .legend-item { display: flex; align-items: center; font-size: 12px; color: #94a3b8; cursor: pointer; }
  .legend-item:hover { color: #e2e8f0; }
  .legend-color { width: 12px; height: 12px; margin-right: 5px; border-radius: 2px; }
  .chart-tooltip {
    position: absolute;
    pointer-events: none;
    background: rgba(15, 23, 42, 0.95);
    border: 1px solid #475569;
    border-radius: 4px;
    padding: 8px;
    font-size: 12px;
    color: #e2e8f0;
  }
  .chart-tooltip .tt-title { font-weight: bold; margin-bottom: 4px; border-bottom: 1px solid #334155; padding-bottom: 4px; }
  .chart-tooltip .tt-row { margin-top: 2px; }
  .range-picker {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 1.5rem 1rem 0;
    flex-wrap: wrap;
  }
  .range-picker a {
    padding: 5px 10px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
    color: #94a3b8;
    text-decoration: none;
    background: rgb(30 41 59);
    border: 1px solid transparent;
  }
  .range-picker a:hover { color: #e2e8f0; }
  .range-picker a.active {
    color: #e2e8f0;
    border-color: #475569;
    background: rgb(51 65 85);
  }
  .range-picker .sep { color: #475569; font-size: 12px; margin: 0 2px; }
  .range-picker input[type="date"] {
    background: rgb(30 41 59);
    border: 1px solid #475569;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 12px;
    padding: 4px 8px;
    color-scheme: dark;
  }
  .range-picker button {
    background: rgb(51 65 85);
    border: 1px solid #475569;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 12px;
    padding: 5px 12px;
    cursor: pointer;
  }
  .range-picker button:hover { background: rgb(71 85 105); }
  .panels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 0 1rem;
  }
  @media (max-width: 768px) {
    .panels { grid-template-columns: 1fr; }
  }
  .panel {
    background-color: rgb(30 41 59);
    border-radius: 8px;
    padding: 16px;
  }
  .panel h2 {
    color: #e2e8f0;
    margin: 0 0 12px 0;
    font-size: 14px;
    font-weight: 600;
  }
  .panel table { width: 100%; }
  .panel td { padding: 4px 0; font-size: 13px; }
  .panel td:last-child { text-align: right; }
  .status-2xx { color: #34d399; }
  .status-3xx { color: #60a5fa; }
  .status-4xx { color: #fbbf24; }
  .status-5xx { color: #f87171; }
  .dur-row { display: flex; align-items: center; gap: 8px; margin: 4px 0; font-size: 13px; }
  .dur-label { width: 60px; text-align: right; color: #94a3b8; flex-shrink: 0; }
  .dur-bar-bg { flex: 1; height: 18px; background: rgb(51 65 85); border-radius: 3px; overflow: hidden; }
  .dur-bar { height: 100%; background: #60a5fa; border-radius: 3px; min-width: 1px; }
  .dur-count { width: 70px; text-align: right; color: #94a3b8; flex-shrink: 0; }

  /* Query builder styles */
  .query-builder {
    margin: 1rem 1rem 0;
    background-color: rgb(30 41 59);
    border-radius: 8px;
    padding: 16px;
  }
  .query-builder h2 {
    color: #e2e8f0;
    margin: 0 0 12px 0;
    font-size: 14px;
    font-weight: 600;
  }
  .query-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .query-row select {
    background: rgb(51 65 85);
    border: 1px solid #475569;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 12px;
    padding: 4px 8px;
  }
  .query-filters {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-wrap: wrap;
  }
  .filter-pill {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: rgb(51 65 85);
    border: 1px solid #475569;
    border-radius: 12px;
    padding: 2px 8px;
    font-size: 11px;
    color: #e2e8f0;
  }
  .filter-pill .remove-filter {
    cursor: pointer;
    color: #94a3b8;
    font-size: 13px;
    line-height: 1;
  }
  .filter-pill .remove-filter:hover { color: #f87171; }
  .query-btn {
    background: none;
    border: 1px solid #475569;
    border-radius: 4px;
    color: #94a3b8;
    font-size: 11px;
    padding: 3px 8px;
    cursor: pointer;
  }
  .query-btn:hover { color: #e2e8f0; border-color: #64748b; }
  .query-btn.remove { color: #f87171; border-color: transparent; }
  .query-btn.remove:hover { color: #ef4444; }
  .filter-add {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }
  .filter-add select {
    background: rgb(51 65 85);
    border: 1px solid #475569;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 11px;
    padding: 2px 6px;
  }
  .negate-toggle {
    background: rgb(51 65 85);
    border: 1px solid #475569;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 11px;
    padding: 2px 8px;
    cursor: pointer;
    min-width: 32px;
    text-align: center;
    font-family: inherit;
  }
  .negate-toggle:hover { border-color: #64748b; }
  .negate-toggle.negated { color: #f87171; border-color: #f87171; }
  .filter-ms { position: relative; display: inline-block; }
  .filter-ms-toggle {
    background: rgb(51 65 85);
    border: 1px solid #475569;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 11px;
    padding: 2px 6px;
    cursor: pointer;
    min-width: 80px;
    text-align: left;
    font-family: inherit;
  }
  .filter-ms-toggle:hover { border-color: #64748b; }
  .filter-ms-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    margin-top: 2px;
    background: rgb(30 41 59);
    border: 1px solid #475569;
    border-radius: 4px;
    padding: 4px 0;
    max-height: 200px;
    overflow-y: auto;
    min-width: 150px;
    z-index: 100;
  }
  .filter-ms-item {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 3px 8px;
    font-size: 11px;
    color: #e2e8f0;
    cursor: pointer;
    white-space: nowrap;
  }
  .filter-ms-item:hover { background: rgb(51 65 85); }
  .filter-ms-item input[type="checkbox"] { margin: 0; accent-color: #60a5fa; }
  .event-json { display: none; }
  .event-json.open { display: block; }
  .event-toggle { cursor: pointer; color: #60a5fa; font-size: 11px; }
  .event-toggle:hover { color: #93c5fd; }
  .json-pre {
    background: rgb(15 23 42);
    border: 1px solid #334155;
    border-radius: 4px;
    padding: 8px;
    font-size: 11px;
    color: #94a3b8;
    overflow-x: auto;
    margin-top: 4px;
    white-space: pre-wrap;
    word-break: break-all;
  }

  /* Logs widget */
  .logs-widget {
    margin: 0 1rem;
    background-color: rgb(30 41 59);
    border-radius: 8px;
    padding: 16px;
  }
  .logs-widget h2 {
    color: #e2e8f0;
    margin: 0 0 12px 0;
    font-size: 14px;
    font-weight: 600;
  }
  #logs-entries {
    max-height: 420px;
    overflow-y: auto;
  }
  .logs-entry {
    border-bottom: 1px solid rgb(51 65 85 / 0.5);
    padding: 1px 0;
  }
  .logs-entry:last-child { border-bottom: none; }
  .logs-entry-header {
    display: flex;
    align-items: center;
    gap: 0;
    cursor: pointer;
    font-size: 12px;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
  }
  .logs-entry-header:hover { background: rgb(51 65 85 / 0.5); }
  .logs-col {
    padding: 0 6px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    color: #94a3b8;
    flex-shrink: 0;
  }
  .logs-col-arrow { width: 18px; text-align: center; font-size: 10px; color: #64748b; transition: transform 0.15s; }
  .logs-col-arrow.open { transform: rotate(90deg); }
  .logs-col-time { width: 188px; }
  .logs-col-level { width: 44px; text-transform: uppercase; }
  .logs-col-level-error { color: #f87171; }
  .logs-col-level-warn { color: #fbbf24; }
  .logs-col-level-info { color: #94a3b8; }
  .logs-col-level-debug { color: #64748b; }
  .logs-col-app { width: 80px; color: #7dd3fc; }
  .logs-col-method { width: 52px; color: #cbd5e1; }
  .logs-col-status { width: 36px; }
  .logs-col-status-2 { color: #4ade80; }
  .logs-col-status-3 { color: #60a5fa; }
  .logs-col-status-4 { color: #fbbf24; }
  .logs-col-status-5 { color: #f87171; }
  .logs-col-reqid { width: 80px; color: #64748b; }
  .logs-col-reqid a { color: #64748b; text-decoration: none; }
  .logs-col-reqid a:hover { color: #94a3b8; text-decoration: underline; }
  .logs-col-duration { width: 64px; text-align: right; color: #94a3b8; }
  .logs-col-msg { width: 72px; color: #94a3b8; }
  .logs-col-path { flex: 1; min-width: 0; color: #cbd5e1; }
  .logs-table-header {
    display: flex;
    align-items: center;
    gap: 0;
    font-size: 11px;
    color: #64748b;
    border-bottom: 1px solid #334155;
    padding-bottom: 4px;
    margin-bottom: 4px;
    font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, monospace;
  }
  .logs-table-header .logs-col { color: #64748b; font-weight: 600; }
  .logs-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-top: 12px;
    font-size: 12px;
    color: #94a3b8;
  }
  .logs-pagination button {
    background: rgb(51 65 85);
    border: 1px solid #475569;
    border-radius: 4px;
    color: #e2e8f0;
    font-size: 12px;
    padding: 4px 12px;
    cursor: pointer;
  }
  .logs-pagination button:hover { background: rgb(71 85 105); }
  .logs-pagination button:disabled { opacity: 0.4; cursor: default; }
  .logs-pagination button:disabled:hover { background: rgb(51 65 85); }
</style>
</head>

<body class="bg-slate-900 text-gray-100">
  <div class="px-4 sm:px-6 lg:px-8">

    <div class="range-picker">
      {{ range .TimeRange.CannedRanges }}
        <a href="?range={{ .Key }}"{{ if .Active }} class="active"{{ end }}>{{ .Label }}</a>
      {{ end }}
      <span class="sep">|</span>
      <form method="get" style="display:contents">
        <input type="date" name="start" value="{{ .TimeRange.Start }}">
        <span class="sep">&ndash;</span>
        <input type="date" name="end" value="{{ .TimeRange.End }}">
        <button type="submit">Apply</button>
      </form>
    </div>

    <div class="query-builder">
      <div id="query-row"></div>
    </div>

    <div class="chart-container">
      <h2>Requests Over Time</h2>
      <div class="legend" id="chart-legend"></div>
      <div class="d3-chart" id="chart"></div>
    </div>

    <div class="logs-widget" id="logs-widget">
      <h2>Logs</h2>
      <div id="logs-entries"></div>
      <div class="logs-pagination" id="logs-pagination"></div>
    </div>

    <div class="panels">
      <div class="panel">
        <h2>Status Codes</h2>
        {{ range .StatusCodes }}
          <div class="dur-row">
            <span class="dur-label {{ if ge .StatusCode 500 }}status-5xx{{ else if ge .StatusCode 400 }}status-4xx{{ else if ge .StatusCode 300 }}status-3xx{{ else }}status-2xx{{ end }}">{{ .StatusCode }}</span>
            <div class="dur-bar-bg"><div class="dur-bar" style="width: {{ percent .RequestCount $.TotalStatusCount }}%; background: {{ if ge .StatusCode 500 }}#f87171{{ else if ge .StatusCode 400 }}#fbbf24{{ else if ge .StatusCode 300 }}#60a5fa{{ else }}#34d399{{ end }}"></div></div>
            <span class="dur-count">{{ percent .RequestCount $.TotalStatusCount }}%</span>
          </div>
        {{ end }}
      </div>
      <div class="panel">
        <h2>Duration Distribution</h2>
        {{ range .Durations }}
          <div class="dur-row">
            <span class="dur-label">{{ if ge .DurationBucket 10000 }}>5s{{ else if ge .DurationBucket 1000 }}{{ divide .DurationBucket 1000 }}s{{ else }}{{ .DurationBucket }}ms{{ end }}</span>
            <div class="dur-bar-bg"><div class="dur-bar" style="width: {{ percent .RequestCount $.TotalDurCount }}%"></div></div>
            <span class="dur-count">{{ percent .RequestCount $.TotalDurCount }}%</span>
          </div>
        {{ end }}
      </div>
    </div>

    <div class="mt-8 flow-root">
      <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
	<div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
	  <table class="min-w-full divide-y divide-gray-300">
	    <thead>
	      <tr>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">Top URLs</th>
		<th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-200">Requests</th>
	      </tr>
	    </thead>
	    <tbody class="divide-y divide-gray-500">
	      {{ range .TopPages }}
		<tr>
		  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">{{ .URL }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-right text-sm">{{ .RequestCount }}</td>
		</tr>
	      {{ end }}
	    </tbody>
	  </table>
	</div>
      </div>
      <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
	<div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
	  <table class="min-w-full divide-y divide-gray-300">
	    <thead>
	      <tr>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">Date</th>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">App</th>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">Method</th>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">URL</th>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">Status</th>
		<th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-gray-200">Duration</th>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">RemoteAddr</th>
		<th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-200">Trace</th>
	      </tr>
	    </thead>
	    <tbody class="divide-y divide-gray-500">
	      {{ range .Events }}
		<tr>
		  <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">{{ formatTime .Timestamp }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm">{{ deref .App }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm">{{ deref .Method }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm">{{ if .Host }}<a class="text-blue-300" href="//{{ deref .Host }}{{ deref .Path }}">{{ deref .Host }}{{ deref .Path }}</a>{{ end }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm">{{ derefInt .Status }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm text-right">{{ formatDuration .DurationMs }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm" {{ if .RemoteAddr }}style="color: {{ colorHash (deref .RemoteAddr) }}"{{ end }}>{{ deref .RemoteAddr }}</td>
		  <td class="whitespace-nowrap px-3 py-4 text-sm">{{ if .RequestID }}<a class="text-blue-300" href="/trace/{{ deref .RequestID }}">{{ deref .RequestID }}</a>{{ end }}</td>
		</tr>
	      {{ end }}
	    </tbody>
	  </table>
	</div>
      </div>
    </div>

  </div>

<script src="https://d3js.org/d3.v7.min.js"></script>
<script>
window.chartData = {{ .ChartJSON }};
window.query = {{ .QueryJSON }};

const colors = ["#60a5fa","#f87171","#34d399","#c084fc","#fbbf24","#fb923c","#2dd4bf","#f472b6"];
const formatDate = d3.timeFormat("%b %d, %H:%M");

const groupByOptions = ["host", "app", "proxy_upstream", "level", "status", "duration_bucket", "method", "route"];

function getRangeParams() {
  const params = new URLSearchParams(window.location.search);
  const out = new URLSearchParams();
  if (params.has("range")) out.set("range", params.get("range"));
  if (params.has("start")) out.set("start", params.get("start"));
  if (params.has("end")) out.set("end", params.get("end"));
  return out;
}

function formatQuery(q) {
  let parts = ["group:" + q.GroupBy];
  if (q.Filters) {
    for (const f of q.Filters) {
      const key = (f.Negate ? "!" : "") + f.Column;
      parts.push(key + ":" + f.Values.join("|"));
    }
  }
  return parts.join(",");
}

function updateURL() {
  const params = getRangeParams();
  params.set("q", formatQuery(window.query));
  history.replaceState(null, "", "?" + params.toString());
}

async function fetchValues(dim) {
  const params = getRangeParams();
  params.set("dim", dim);
  const resp = await fetch("values?" + params.toString());
  return resp.json();
}

async function fetchQueryData(q) {
  const params = getRangeParams();
  params.set("q", formatQuery(q));
  const resp = await fetch("query?" + params.toString());
  return resp.json();
}

async function refreshChart() {
  const data = await fetchQueryData(window.query);
  window.chartData = data;
  renderChart(data);
  updateURL();
  refreshLogs(1);
}

function renderQueryBuilder() {
  const container = document.getElementById("query-row");
  container.innerHTML = "";
  const q = window.query;

  const row = document.createElement("div");
  row.className = "query-row";

  const grpSel = document.createElement("select");
  grpSel.title = "Group by";
  groupByOptions.forEach(g => {
    const opt = document.createElement("option");
    opt.value = g;
    opt.textContent = "group: " + g;
    opt.selected = q.GroupBy === g;
    grpSel.appendChild(opt);
  });
  grpSel.addEventListener("change", () => {
    q.GroupBy = grpSel.value;
    refreshChart();
  });
  row.appendChild(grpSel);

  const filtersDiv = document.createElement("div");
  filtersDiv.className = "query-filters";
  if (q.Filters) {
    q.Filters.forEach((f, fi) => {
      const pill = document.createElement("span");
      pill.className = "filter-pill";
      const op = f.Negate
        ? (f.Values.length > 1 ? " not in " : " \u2260 ")
        : (f.Values.length > 1 ? " in " : " = ");
      const valText = f.Values.length > 1 ? f.Values.join(", ") : f.Values[0];

      const labelSpan = document.createElement("span");
      labelSpan.className = "filter-label";
      labelSpan.textContent = f.Column + op + valText;
      labelSpan.title = "Click to toggle negation";
      labelSpan.style.cursor = "pointer";
      labelSpan.addEventListener("click", () => {
        f.Negate = !f.Negate;
        renderQueryBuilder();
        refreshChart();
      });
      pill.appendChild(labelSpan);

      const removeSpan = document.createElement("span");
      removeSpan.className = "remove-filter";
      removeSpan.textContent = "\u00d7";
      removeSpan.addEventListener("click", () => {
        q.Filters.splice(fi, 1);
        renderQueryBuilder();
        refreshChart();
      });
      pill.appendChild(removeSpan);

      filtersDiv.appendChild(pill);
    });
  }

  const addFilterBtn = document.createElement("button");
  addFilterBtn.className = "query-btn";
  addFilterBtn.textContent = "+filter";
  addFilterBtn.addEventListener("click", () => {
    addFilterBtn.style.display = "none";
    const addDiv = document.createElement("span");
    addDiv.className = "filter-add";

    let negate = false;
    let selectedValues = new Set();

    const dimSel = document.createElement("select");
    const availDims = groupByOptions;
    const placeholder = document.createElement("option");
    placeholder.textContent = "dimension...";
    placeholder.value = "";
    dimSel.appendChild(placeholder);
    availDims.forEach(d => {
      const opt = document.createElement("option");
      opt.value = d;
      opt.textContent = d;
      dimSel.appendChild(opt);
    });
    addDiv.appendChild(dimSel);

    const negBtn = document.createElement("button");
    negBtn.className = "negate-toggle";
    negBtn.type = "button";
    negBtn.textContent = "=";
    negBtn.title = "Toggle: equals / not equals";
    negBtn.style.display = "none";
    negBtn.addEventListener("click", () => {
      negate = !negate;
      negBtn.textContent = negate ? "\u2260" : "=";
      negBtn.classList.toggle("negated", negate);
    });
    addDiv.appendChild(negBtn);

    const msContainer = document.createElement("span");
    msContainer.className = "filter-ms";
    msContainer.style.display = "none";

    const msBtn = document.createElement("button");
    msBtn.className = "filter-ms-toggle";
    msBtn.type = "button";
    msBtn.textContent = "select values...";
    msContainer.appendChild(msBtn);

    const msDropdown = document.createElement("div");
    msDropdown.className = "filter-ms-dropdown";
    msDropdown.style.display = "none";
    msContainer.appendChild(msDropdown);
    addDiv.appendChild(msContainer);

    const applyBtn = document.createElement("button");
    applyBtn.className = "query-btn";
    applyBtn.type = "button";
    applyBtn.textContent = "apply";
    applyBtn.style.display = "none";
    addDiv.appendChild(applyBtn);

    const cancelBtn = document.createElement("button");
    cancelBtn.className = "query-btn remove";
    cancelBtn.type = "button";
    cancelBtn.textContent = "\u00d7";
    cancelBtn.addEventListener("click", () => {
      addDiv.remove();
      addFilterBtn.style.display = "";
    });
    addDiv.appendChild(cancelBtn);

    function updateMsBtnText() {
      if (selectedValues.size === 0) {
        msBtn.textContent = "select values...";
        applyBtn.style.display = "none";
      } else {
        const arr = Array.from(selectedValues);
        msBtn.textContent = arr.length <= 2 ? arr.join(", ") : arr.length + " selected";
        applyBtn.style.display = "";
      }
    }

    dimSel.addEventListener("change", async () => {
      if (!dimSel.value) {
        negBtn.style.display = "none";
        msContainer.style.display = "none";
        applyBtn.style.display = "none";
        return;
      }
      negBtn.style.display = "";
      msContainer.style.display = "inline-block";
      msBtn.textContent = "loading...";
      msDropdown.innerHTML = "";
      selectedValues.clear();
      applyBtn.style.display = "none";

      const vals = await fetchValues(dimSel.value);
      msBtn.textContent = "select values...";
      (vals || []).forEach(v => {
        const item = document.createElement("label");
        item.className = "filter-ms-item";
        const cb = document.createElement("input");
        cb.type = "checkbox";
        cb.value = v;
        cb.addEventListener("change", () => {
          if (cb.checked) selectedValues.add(v);
          else selectedValues.delete(v);
          updateMsBtnText();
        });
        const span = document.createElement("span");
        span.textContent = v;
        item.appendChild(cb);
        item.appendChild(span);
        msDropdown.appendChild(item);
      });
    });

    msBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      msDropdown.style.display = msDropdown.style.display === "none" ? "" : "none";
    });

    const closeHandler = (e) => {
      if (!msContainer.contains(e.target)) {
        msDropdown.style.display = "none";
      }
      if (!document.body.contains(addDiv)) {
        document.removeEventListener("click", closeHandler);
      }
    };
    document.addEventListener("click", closeHandler);

    applyBtn.addEventListener("click", () => {
      if (selectedValues.size === 0) return;
      if (!q.Filters) q.Filters = [];
      const values = Array.from(selectedValues);
      const existing = q.Filters.find(f => f.Column === dimSel.value && f.Negate === negate);
      if (existing) {
        values.forEach(v => {
          if (!existing.Values.includes(v)) existing.Values.push(v);
        });
      } else {
        q.Filters.push({Column: dimSel.value, Negate: negate, Values: values});
      }
      renderQueryBuilder();
      refreshChart();
    });

    filtersDiv.appendChild(addDiv);
  });
  filtersDiv.appendChild(addFilterBtn);
  row.appendChild(filtersDiv);

  container.appendChild(row);
}

function toggleLegendFilter(value) {
  const q = window.query;
  const dim = q.GroupBy;
  if (!q.Filters) q.Filters = [];

  const existing = q.Filters.find(f => f.Column === dim && f.Negate);
  if (existing) {
    const idx = existing.Values.indexOf(value);
    if (idx >= 0) {
      existing.Values.splice(idx, 1);
      if (existing.Values.length === 0) {
        q.Filters = q.Filters.filter(f => f !== existing);
      }
    } else {
      existing.Values.push(value);
    }
  } else {
    q.Filters.push({Column: dim, Negate: true, Values: [value]});
  }

  renderQueryBuilder();
  renderChart(window.chartData);
  updateURL();
}

function renderChart(data) {
  const dataKeys = Object.keys(data || {});
  const chartDiv = document.getElementById("chart");
  const legendEl = document.getElementById("chart-legend");

  chartDiv.innerHTML = "";
  legendEl.innerHTML = "";
  d3.selectAll(".chart-tooltip").remove();

  const q = window.query;
  const hiddenKeys = new Set();
  if (q.Filters) {
    q.Filters.forEach(f => {
      if (f.Column === q.GroupBy && f.Negate) {
        f.Values.forEach(v => hiddenKeys.add(v));
      }
    });
  }

  const keys = Array.from(new Set([...dataKeys, ...hiddenKeys]));
  keys.sort();

  if (keys.length === 0) return;

  const timeSet = new Set();
  dataKeys.forEach(k => {
    (data[k] || []).forEach(p => timeSet.add(p.window_start_at));
  });
  const times = Array.from(timeSet).sort();

  const lookup = {};
  dataKeys.forEach(k => {
    lookup[k] = {};
    (data[k] || []).forEach(p => { lookup[k][p.window_start_at] = p.count; });
  });

  const stackData = times.map(t => {
    const obj = { _time: new Date(t) };
    dataKeys.forEach(k => { obj[k] = lookup[k][t] || 0; });
    return obj;
  });

  keys.forEach((key, i) => {
    const hidden = hiddenKeys.has(key);
    const item = document.createElement("div");
    item.className = "legend-item";
    if (hidden) item.style.opacity = "0.35";
    const swatch = document.createElement("div");
    swatch.className = "legend-color";
    swatch.style.backgroundColor = colors[i % colors.length];
    const label = document.createElement("span");
    label.textContent = key;
    item.appendChild(swatch);
    item.appendChild(label);
    item.addEventListener("click", () => toggleLegendFilter(key));
    legendEl.appendChild(item);
  });

  const visibleKeys = keys.filter(k => !hiddenKeys.has(k));

  if (stackData.length === 0 || visibleKeys.length === 0) return;

  const margin = {top: 10, right: 20, bottom: 30, left: 50};
  const width = chartDiv.clientWidth - margin.left - margin.right;
  const height = chartDiv.clientHeight - margin.top - margin.bottom;

  const svg = d3.select("#chart").append("svg")
    .attr("width", width + margin.left + margin.right)
    .attr("height", height + margin.top + margin.bottom)
    .append("g")
    .attr("transform", `translate(${margin.left},${margin.top})`);

  let windowMs;
  if (stackData.length > 1) {
    windowMs = d3.min(d3.pairs(stackData, (a, b) => b._time - a._time));
  } else {
    windowMs = 3600000; // 1h fallback
  }

  const xScale = d3.scaleTime()
    .domain([stackData[0]._time, new Date(stackData[stackData.length - 1]._time.getTime() + windowMs)])
    .range([0, width]);

  const barWidth = Math.max(1, xScale(new Date(stackData[0]._time.getTime() + windowMs)) - xScale(stackData[0]._time) - 1);

  const series = d3.stack().keys(visibleKeys)(stackData);

  const yMax = d3.max(stackData, d => visibleKeys.reduce((sum, k) => sum + d[k], 0));
  const yScale = d3.scaleLinear()
    .domain([0, yMax * 1.1])
    .range([height, 0]);

  svg.append("g").attr("class", "grid").attr("transform", `translate(0,${height})`)
    .call(d3.axisBottom(xScale).ticks(10).tickSize(-height).tickFormat(""));
  svg.append("g").attr("class", "grid")
    .call(d3.axisLeft(yScale).ticks(5).tickSize(-width).tickFormat(""));

  svg.append("g").attr("class", "x axis").attr("transform", `translate(0,${height})`)
    .call(d3.axisBottom(xScale).ticks(width > 600 ? 10 : 5).tickFormat(formatDate));
  svg.append("g").attr("class", "y axis")
    .call(d3.axisLeft(yScale).ticks(5));

  series.forEach((s, si) => {
    const keyIndex = keys.indexOf(visibleKeys[si]);
    svg.selectAll(null)
      .data(s)
      .enter()
      .append("rect")
      .attr("x", d => xScale(d.data._time))
      .attr("y", d => yScale(d[1]))
      .attr("height", d => Math.max(0, yScale(d[0]) - yScale(d[1])))
      .attr("width", barWidth)
      .attr("fill", colors[keyIndex % colors.length]);
  });

  const tooltip = d3.select("body").append("div")
    .attr("class", "chart-tooltip")
    .style("opacity", 0);

  svg.append("rect")
    .attr("width", width).attr("height", height)
    .style("fill", "none").style("pointer-events", "all")
    .on("mouseover", () => tooltip.transition().duration(200).style("opacity", 0.9))
    .on("mouseout", () => tooltip.transition().duration(500).style("opacity", 0))
    .on("mousemove", function(event) {
      const x0 = xScale.invert(d3.pointer(event)[0]);
      const bisect = d3.bisector(d => d._time).left;
      const idx = bisect(stackData, x0, 1);
      let d;
      if (idx > 0 && idx < stackData.length) {
        const d0 = stackData[idx - 1], d1 = stackData[idx];
        d = (x0 - d0._time > d1._time - x0) ? d1 : d0;
      } else {
        d = idx === 0 ? stackData[0] : stackData[stackData.length - 1];
      }

      let html = `<div class="tt-title">${formatDate(d._time)}</div>`;
      let total = 0;
      const rows = visibleKeys.map(k => ({key: k, color: colors[keys.indexOf(k) % colors.length], count: d[k]}))
        .filter(r => r.count > 0)
        .sort((a, b) => b.count - a.count);
      rows.forEach(r => {
        total += r.count;
        html += `<div class="tt-row" style="color:${r.color}">${r.key}: ${r.count}</div>`;
      });
      if (visibleKeys.length > 1) {
        html += `<div class="tt-row" style="color:#e2e8f0; border-top: 1px solid #334155; margin-top: 4px; padding-top: 4px;">total: ${total}</div>`;
      }
      tooltip.html(html)
        .style("left", (event.pageX + 10) + "px")
        .style("top", (event.pageY - 28) + "px");
    });
}

let logsCurrentPage = 1;

async function refreshLogs(page) {
  logsCurrentPage = page;
  const params = getRangeParams();
  const q = window.query;
  params.set("q", formatQuery(q));
  params.set("page", page);
  params.set("limit", 50);

  const resp = await fetch("events?" + params.toString());
  const result = await resp.json();
  renderLogs(result);
}

function renderLogs(result) {
  const container = document.getElementById("logs-entries");
  const pagination = document.getElementById("logs-pagination");
  container.innerHTML = "";
  pagination.innerHTML = "";

  const events = result.events || [];
  const total = result.total || 0;
  const page = result.page || 1;
  const pageSize = result.pageSize || 50;
  const totalPages = Math.max(1, Math.ceil(total / pageSize));

  if (events.length === 0) {
    container.innerHTML = '<div style="color:#64748b;font-size:13px;padding:8px 0">No matching events.</div>';
    return;
  }

  // Table header row.
  const thead = document.createElement("div");
  thead.className = "logs-table-header";
  const thCols = [
    ["logs-col logs-col-arrow", ""],
    ["logs-col logs-col-time", "Time"],
    ["logs-col logs-col-level", "Lvl"],
    ["logs-col logs-col-app", "App"],
    ["logs-col logs-col-reqid", "ReqID"],
    ["logs-col logs-col-method", "Method"],
    ["logs-col logs-col-status", "St"],
    ["logs-col logs-col-duration", "Dur"],
    ["logs-col logs-col-msg", "Msg"],
    ["logs-col logs-col-path", "Path"],
  ];
  thCols.forEach(([cls, label]) => {
    const col = document.createElement("span");
    col.className = cls;
    col.textContent = label;
    thead.appendChild(col);
  });
  container.appendChild(thead);

  events.forEach(ev => {
    const entry = document.createElement("div");
    entry.className = "logs-entry";

    const header = document.createElement("div");
    header.className = "logs-entry-header";

    const arrow = document.createElement("span");
    arrow.className = "logs-col logs-col-arrow";
    arrow.textContent = "\u25b6";

    const ts = document.createElement("span");
    ts.className = "logs-col logs-col-time";
    const d = new Date(ev.timestamp);
    ts.textContent = d.toISOString().replace("T", " ").substring(0, 19);

    const level = document.createElement("span");
    const lvl = (ev.level || "").toLowerCase();
    level.className = "logs-col logs-col-level logs-col-level-" + (lvl || "info");
    level.textContent = lvl || "";

    const app = document.createElement("span");
    app.className = "logs-col logs-col-app";
    app.textContent = ev.app || "";

    const reqid = document.createElement("span");
    reqid.className = "logs-col logs-col-reqid";
    if (ev.request_id) {
      const reqLink = document.createElement("a");
      reqLink.href = "trace/" + ev.request_id;
      reqLink.textContent = ev.request_id.substring(0, 8);
      reqLink.addEventListener("click", e => e.stopPropagation());
      reqid.appendChild(reqLink);
    }

    const method = document.createElement("span");
    method.className = "logs-col logs-col-method";
    method.textContent = ev.method || "";

    const status = document.createElement("span");
    const sc = ev.status ? String(ev.status) : "";
    const sclass = sc ? "logs-col-status-" + sc.charAt(0) : "";
    status.className = "logs-col logs-col-status " + sclass;
    status.textContent = sc;

    const duration = document.createElement("span");
    duration.className = "logs-col logs-col-duration";
    if (ev.duration_ms != null) {
      duration.textContent = ev.duration_ms < 1000
        ? Math.round(ev.duration_ms) + "ms"
        : (ev.duration_ms / 1000).toFixed(1) + "s";
    }

    const msg = document.createElement("span");
    msg.className = "logs-col logs-col-msg";
    msg.textContent = ev.msg || "";

    const path = document.createElement("span");
    path.className = "logs-col logs-col-path";
    path.textContent = (ev.host || "") + (ev.path || "");

    header.appendChild(arrow);
    header.appendChild(ts);
    header.appendChild(level);
    header.appendChild(app);
    header.appendChild(reqid);
    header.appendChild(method);
    header.appendChild(status);
    header.appendChild(duration);
    header.appendChild(msg);
    header.appendChild(path);

    const jsonDiv = document.createElement("div");
    jsonDiv.className = "event-json";
    const pre = document.createElement("pre");
    pre.className = "json-pre";
    try {
      pre.textContent = JSON.stringify(ev.data, null, 2);
    } catch (e) {
      pre.textContent = String(ev.data);
    }
    jsonDiv.appendChild(pre);

    header.addEventListener("click", () => {
      const open = jsonDiv.classList.toggle("open");
      arrow.classList.toggle("open", open);
    });

    entry.appendChild(header);
    entry.appendChild(jsonDiv);
    container.appendChild(entry);
  });

  // Pagination controls.
  const prevBtn = document.createElement("button");
  prevBtn.textContent = "Previous";
  prevBtn.disabled = page <= 1;
  prevBtn.addEventListener("click", () => refreshLogs(page - 1));

  const info = document.createElement("span");
  info.textContent = "Page " + page + " of " + totalPages + " (" + total + " events)";

  const nextBtn = document.createElement("button");
  nextBtn.textContent = "Next";
  nextBtn.disabled = page >= totalPages;
  nextBtn.addEventListener("click", () => refreshLogs(page + 1));

  pagination.appendChild(prevBtn);
  pagination.appendChild(info);
  pagination.appendChild(nextBtn);
}

document.addEventListener("DOMContentLoaded", function() {
  renderQueryBuilder();
  renderChart(window.chartData);
  refreshLogs(1);

  document.querySelectorAll('.range-picker a').forEach(a => {
    a.addEventListener('click', (e) => {
      e.preventDefault();
      const params = new URLSearchParams(window.location.search);
      const linkParams = new URL(a.href, window.location.origin).searchParams;
      params.delete('start');
      params.delete('end');
      params.set('range', linkParams.get('range'));
      window.location.search = params.toString();
    });
  });

  const dateForm = document.querySelector('.range-picker form');
  if (dateForm) {
    dateForm.addEventListener('submit', () => {
      const q = new URLSearchParams(window.location.search).get('q');
      if (q) {
        let hidden = dateForm.querySelector('input[name="q"]');
        if (!hidden) {
          hidden = document.createElement('input');
          hidden.type = 'hidden';
          hidden.name = 'q';
          dateForm.appendChild(hidden);
        }
        hidden.value = q;
      }
    });
  }
});
</script>
</body>

</html>
