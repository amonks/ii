FROM alpine
  RUN apk add --no-cache ca-certificates
  WORKDIR /app/apps/mailer
  COPY --from=gobuild /app/bin/mailer /app/bin/app
  ENV MONKS_ROOT=/app
  ENV MONKS_DATA=/tmp
  CMD ["/app/bin/app"]
