# Test that the agent can use the bash tool to execute commands.
# This verifies that tool call arguments are properly parsed.

# Setup: create repo and copy the real config
mkdir repo
cd repo
exec jj git init
cp ../incrementum.toml incrementum.toml

# Run agent asking it to use bash to create a file
exec $II agent run --model claude-haiku-4-5 'Use the bash tool to run: echo "hello from bash" > output.txt'

# Verify the file was created with correct content
exec cat output.txt
stdout 'hello from bash'
