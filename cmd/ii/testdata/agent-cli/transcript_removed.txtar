# Ensure deprecated `ii agent transcript` is removed.
#
# The transcript command should not exist. When an unknown subcommand is passed,
# Cobra shows the parent command's help (listing available subcommands).
# We verify that 'transcript' does not appear as an available command name.

# setup repo and copy the real config
mkdir repo
cd repo
exec jj git init
cp $WORK/incrementum.toml incrementum.toml

# Running 'ii agent transcript' should show help (not execute a transcript command)
exec $II agent transcript some-id

# The available commands should NOT include 'transcript' as a command name.
# Note: 'transcript' may appear in descriptions, but not as a command name at the start of a line.
! stdout '^\s*transcript\s'

# The help output SHOULD mention the valid commands
stdout 'logs'
stdout 'tail'
