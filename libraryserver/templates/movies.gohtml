<!doctype html>
<html>
<head>
<title>movies</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
<ul role="list" class="movies grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 sm:gap-x-6 lg:grid-cols-4 xl:gap-x-8">
  {{ range $movie := .Movies }}
  <li class="movie relative">
      <div class="group aspect-h-7 aspect-w-10 block w-full overflow-hidden rounded-lg bg-gray-100 focus-within:ring-2 focus-within:ring-indigo-500 focus-within:ring-offset-2 focus-within:ring-offset-gray-100">
	<img src="{{ .PosterURL }}" alt="" class="pointer-events-none object-cover group-hover:opacity-75">
	<button type="button" class="absolute inset-0 focus:outline-none">
	  <span class="sr-only">View details for IMG_4985.HEIC</span>
	</button>
      </div>
      <p data-role="id"            class="pointer-events-none block text-sm font-medium text-gray-900">{{ .ID }}</p>
      <p data-role="title"         class="pointer-events-none block text-sm font-medium text-gray-900">{{ .Title }}</p>
      <p data-role="release-date"  class="pointer-events-none block text-sm font-medium text-gray-500">{{ .ReleaseDate }}</p>
      <p data-role="tagline"       class="pointer-events-none block text-sm font-medium text-gray-500">{{ .Tagline }}</p>
      <p data-role="genres"        class="pointer-events-none block text-sm font-medium text-gray-500">{{ .Genres }}</p>
      <p data-role="runtime"       class="pointer-events-none block text-sm font-medium text-gray-500">{{ .Runtime }} minutes</p>
    </li>
  {{ end }}
</ul>
<script src="/script"></script>
</body>
</html>

