<!doctype html>
<html>
<head>
<title>movies</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
<div class="bg-white">
  <div>
    <main class="mx-auto px-4 py-16 sm:px-6 sm:py-24 px-8">
      <div class="pt-12 grid grid-cols-6 gap-x-8">
        <aside>
          <div class="block">
            <form class="space-y-10">

              <div class="pb-4 pt-4">
                <label class="block text-sm font-medium leading-6 text-gray-900">Sort by…</label>
                <fieldset id="sort-by" class="mt-4">
                  <div class="space-y-4">
                    <div class="flex items-center">
                      <input id="sort-date" name="sort-by" type="radio" {{ if eq .SortBy "date" }}checked{{ end }} class="h-4 w-4 border-gray-300 text-indigo-600 focus:ring-indigo-600">
                      <label for="sort-date" class="ml-3 block text-sm font-medium leading-6 text-gray-900">Release date</label>
                    </div>
                    <div class="flex items-center">
                      <input id="sort-name" name="sort-by" type="radio" {{ if eq .SortBy "name" }}checked{{ end }} class="h-4 w-4 border-gray-300 text-indigo-600 focus:ring-indigo-600">
                      <label for="sort-name" class="ml-3 block text-sm font-medium leading-6 text-gray-900">Name</label>
                    </div>
                    <div class="flex items-center">
                      <input id="sort-runtime" name="sort-by" type="radio" {{ if eq .SortBy "runtime" }}checked{{ end }} class="h-4 w-4 border-gray-300 text-indigo-600 focus:ring-indigo-600">
                      <label for="sort-runtime" class="ml-3 block text-sm font-medium leading-6 text-gray-900">Runtime</label>
                    </div>
                  </div>
                </fieldset>
              </div>

              <div class="pb-4 pt-4">
                <label class="block text-sm font-medium leading-6 text-gray-900">Sort direction</label>
                <fieldset id="sort-direction" class="mt-4">
                  <div class="space-y-4">
                    <div class="flex items-center">
                      <input id="sort-direction-asc" name="sort-direction" type="radio" {{ if eq .SortDirection "asc" }}checked{{ end }} class="h-4 w-4 border-gray-300 text-indigo-600 focus:ring-indigo-600">
                      <label for="sort-direction-asc" class="ml-3 block text-sm font-medium leading-6 text-gray-900">Ascending</label>
                    </div>
                    <div class="flex items-center">
                      <input id="sort-direction-desc" name="sort-direction" type="radio" {{ if eq .SortDirection "desc" }}checked{{ end }} class="h-4 w-4 border-gray-300 text-indigo-600 focus:ring-indigo-600">
                      <label for="sort-direction-desc" class="ml-3 block text-sm font-medium leading-6 text-gray-900">Descending</label>
                    </div>
                  </div>
                </fieldset>
              </div>

              <div class="pb-4 pt-4">
                <fieldset>
                  <div class="space-y-6">
                    <label for="query" class="block text-sm font-medium leading-6 text-gray-900">Search</label>
                    <input type="text" name="query" id="query" value="{{ .Query }}" class="block w-full rounded-md border-0 py-1.5 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm sm:leading-6">
                  </div>
                </fieldset>
              </div>

              <div class="pb-4 pt-4">
                <fieldset>
                  <legend class="block text-sm font-medium text-gray-900">Genre</legend>
                  <div class="space-y-3 pt-6">
                    {{ range $genre := .Genres }}
                      <div class="flex items-center">
                        <input id="genre-{{ $genre.Name }}" name="genres[]" value="{{ $genre.Name }}" {{ if $genre.IsSelected }}checked{{ end }} type="checkbox" class="h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                        <label for="genre-{{ $genre.Name }}" class="ml-3 text-sm text-gray-600">{{ $genre.Name }}</label>
                      </div>
                    {{ end }}
                  </div>
                </fieldset>
              </div>

            </form>
          </div>
        </aside>

        <!-- Product grid -->
        <div class="mt-6 col-span-5 mt-0">
	  <ul role="list" class="movies grid grid-cols-2 gap-x-4 gap-y-8 sm:grid-cols-3 sm:gap-x-6 lg:grid-cols-4 xl:gap-x-8">
	    {{ range $movie := .Movies }}
	    <li>
                <div data-path="{{ .LibraryPath }}" class="movie cursor-pointer group aspect-h-7 aspect-w-10 block w-full overflow-hidden rounded-lg bg-gray-100 focus-within:ring-2 focus-within:ring-indigo-500 focus-within:ring-offset-2 focus-within:ring-offset-gray-100">
		  <img src="{{ .PosterURL }}" alt="" class="pointer-events-none object-cover group-hover:opacity-75">
		</div>
		<p data-role="title"         class="block text-sm font-medium text-gray-900">{{ .Title }}</p>
		<p data-role="release-date"  class="block text-sm font-medium text-gray-500">{{ .ReleaseDate }}</p>
		<p data-role="tagline"       class="block text-sm font-medium text-gray-500">{{ .Tagline }}</p>
		<p data-role="genres"        class="block text-sm font-medium text-gray-500">{{ .Genres }}</p>
		<p data-role="runtime"       class="block text-sm font-medium text-gray-500">{{ .Runtime }} minutes</p>
	      </li>
	    {{ end }}
	  </ul>
        </div>
      </div>
    </main>
  </div>
</div>

<script type="application/javascript">
  const queryInput = document.querySelector('#query');
  queryInput.addEventListener("blur", ev => {
    const url = new URL(document.location);
    url.searchParams.set("query", queryInput.value);
    window.location = url.toString();
  })

  const sortByInputs = document.querySelectorAll('#sort-by input');
  for (const el of sortByInputs) {
    el.addEventListener("click", ev => {
      const value = el.id.replace("sort-", "");
      console.log(el, value);
      const url = new URL(document.location);
      url.searchParams.set("sortBy", value);
      window.location = url.toString();
    })
  }

  const sortDirectionInputs = document.querySelectorAll('#sort-direction input');
  for (const el of sortDirectionInputs) {
    el.addEventListener("click", ev => {
      const value = el.id.replace("sort-direction-", "");
      console.log(el, value);
      const url = new URL(document.location);
      url.searchParams.set("sortDirection", value);
      window.location = url.toString();
    })
  }

  const genreInputs = document.querySelectorAll('input[name="genres[]"]');
  for (const el of genreInputs) {
    el.addEventListener("click", ev => {
      if (!el.checked) {
        const url = new URL(document.location);
        url.searchParams.delete("genres", el.value);
        window.location = url.toString();
      } else {
        const url = new URL(document.location);
        url.searchParams.append("genres", el.value);
        window.location = url.toString();
      }
    })
  }

  const movies = document.querySelectorAll('.movie');
  for (const el of movies) {
    const path = el.attributes.getNamedItem("data-path").value;
    el.addEventListener("click", ev => {
      window.alert("sftp://ajm@thor/mypool/tank/movies/"+path);
    })
  }
</script>
</body>
</html>

